#!/bin/bash
#
# Pre-commit hook: 根目录清洁度检查
# 
# 功能:
# 1. 检查是否有临时文件被添加到根目录
# 2. 阻止不规范的提交
# 3. 提供清理建议
#
# 安装:
#   cp .lingma/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

# 颜色定义
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "=========================================="
echo "  🔍 根目录清洁度检查"
echo "=========================================="
echo ""

# 获取暂存的文件列表
STAGED_FILES=$(git diff --cached --name-only --diff-filter=A)

# 检查根目录的新文件（不包含路径分隔符的）
ROOT_NEW_FILES=$(echo "$STAGED_FILES" | grep -E "^[^/]+$" | grep -vE "^(README\.md|LICENSE|\.gitignore|\.gitattributes)$" || true)

if [ -n "$ROOT_NEW_FILES" ]; then
    echo -e "${RED}❌ 错误: 检测到根目录有新文件:${NC}"
    echo ""
    echo "$ROOT_NEW_FILES" | while read file; do
        echo "  - $file"
    done
    echo ""
    echo -e "${YELLOW}💡 建议:${NC}"
    echo "  根目录应该保持清洁，请将文件移动到合适的子目录:"
    echo "    - 文档 -> docs/"
    echo "    - 脚本 -> scripts/"
    echo "    - 测试 -> tests/"
    echo "    - 配置 -> config/"
    echo ""
    echo "  如果确实需要在根目录，请更新 .gitignore 或联系团队。"
    echo ""
    
    # 检查是否是常见的临时文件
    TEMP_PATTERN="^[0-9]|^\$null|null|\.log$|\.tmp$|\.temp$|\.bak$"
    TEMP_FILES=$(echo "$ROOT_NEW_FILES" | grep -E "$TEMP_PATTERN" || true)
    
    if [ -n "$TEMP_FILES" ]; then
        echo -e "${RED}🚨 严重: 检测到临时文件，必须删除!${NC}"
        echo ""
        echo "$TEMP_FILES" | while read file; do
            echo "  删除命令: rm \"$file\""
        done
        echo ""
        exit 1
    fi
    
    # 对于非临时文件，给出警告但允许通过（需要确认）
    echo -e "${YELLOW}⚠️  警告: 这些文件可能不应该在根目录${NC}"
    echo ""
    read -p "是否继续提交? (y/N): " -n 1 -r
    echo ""
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo -e "${RED}❌ 提交已取消${NC}"
        exit 1
    fi
fi

# 检查是否有未跟踪的临时文件
UNTRACKED_TEMP=$(git ls-files --others --exclude-standard | grep -E "^[0-9]|^\$null$|^null$|\.log$|\.tmp$" || true)

if [ -n "$UNTRACKED_TEMP" ]; then
    echo -e "${YELLOW}⚠️  警告: 检测到未跟踪的临时文件:${NC}"
    echo ""
    echo "$UNTRACKED_TEMP" | while read file; do
        echo "  - $file"
    done
    echo ""
    echo -e "${YELLOW}💡 这些文件已被 .gitignore 忽略，但建议手动删除以保持清洁${NC}"
    echo ""
fi

echo -e "${GREEN}✅ 根目录清洁度检查通过${NC}"
echo ""
echo "=========================================="

exit 0
