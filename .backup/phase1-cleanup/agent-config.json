{
  "agent": {
    "name": "SpecDrivenAgent",
    "version": "1.0.0",
    "description": "Spec-Driven Development Agent with autonomous execution capabilities",
    "capabilities": [
      "task_planning",
      "skill_execution",
      "rule_enforcement",
      "mcp_integration",
      "context_management"
    ]
  },
  "execution": {
    "max_retries": 3,
    "retry_delay_seconds": 2,
    "timeout_seconds": 300,
    "parallel_tasks": false
  },
  "memory": {
    "short_term": {
      "enabled": true,
      "max_messages": 50,
      "compression_threshold": 40
    },
    "long_term": {
      "enabled": true,
      "storage_path": ".lingma/state/agent-memory.json",
      "retention_days": 30
    }
  },
  "skills": {
    "auto_load": true,
    "search_paths": [
      ".lingma/skills"
    ],
    "cache_enabled": true
  },
  "rules": {
    "enforcement_level": "strict",
    "search_paths": [
      ".lingma/rules"
    ],
    "global_rules": [
      "spec-session-start.md"
    ]
  },
  "mcp": {
    "enabled": false,
    "servers": {},
    "timeout_seconds": 30,
    "retry_on_failure": true
  },
  "logging": {
    "level": "INFO",
    "format": "json",
    "output_paths": [
      ".lingma/logs/agent.log",
      ".lingma/logs/agent-audit.log"
    ]
  }
}
