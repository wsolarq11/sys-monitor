{
  "dashboard": {
    "id": null,
    "title": "SysMonitor Runtime Dashboard",
    "tags": ["sysmonitor", "monitoring"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Application Errors",
        "type": "stat",
        "targets": [
          {
            "expr": "count_over_time({app=\"sys-monitor\"} | json | level=\"ERROR\" [1h])",
            "legendFormat": "Errors",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Performance Metrics",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate({app=\"sys-monitor\"} | json | message=~\"Web Vitals.*\" [5m])",
            "legendFormat": "Web Vitals",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Memory Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
            "legendFormat": "Used Memory",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "CPU Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "CPU Usage %",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 8
        }
      },
      {
        "id": 5,
        "title": "Application Logs",
        "type": "logs",
        "targets": [
          {
            "expr": "{app=\"sys-monitor\"}",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 8
        }
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    },
    "refresh": "5s",
    "schemaVersion": 36,
    "version": 0,
    "uid": "sysmonitor-dashboard"
  },
  "folderId": 0,
  "message": "Updated SysMonitor dashboard",
  "overwrite": false
}