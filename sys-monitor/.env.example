# GitHub API 配置
# 复制此文件为 .env 并填入实际值

# GitHub Personal Access Token
# 获取方式: https://github.com/settings/tokens
# 需要权限: repo, workflow
VITE_GITHUB_TOKEN=ghp_your_personal_access_token_here

# GitHub 用户名或组织名
VITE_GITHUB_OWNER=your-username

# 仓库名称
VITE_GITHUB_REPO=FolderSizeMonitor

# 构建状态刷新间隔（毫秒，可选，默认 60000）
VITE_BUILD_REFRESH_INTERVAL=60000
