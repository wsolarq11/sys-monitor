# ============================================
# 操作系统文件
# ============================================
.DS_Store
Thumbs.db
desktop.ini
$null
null

# ============================================
# 对话和笔记产生的临时文件（数字、百分比等）
# ============================================
[0-9]*
[0-9]*%
[0-9]*ms
[0-9]*条*
*条记忆*

# ============================================
# 编辑器和 IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# 构建输出
# ============================================
node_modules/
dist/
build/
out/
target/
*.pyc
__pycache__/

# ============================================
# 日志和临时文件
# ============================================
*.log
*.tmp
*.temp
*.bak
*.backup

# ============================================
# 测试和调试
# ============================================
coverage/
.nyc_output/
test-results/
*.prof
*.trace

# ============================================
# 环境配置（敏感信息）
# ============================================
.env
.env.local
.env.*.local

# ============================================
# 包管理器
# ============================================
package-lock.json
yarn.lock
pnpm-lock.yaml
poetry.lock

# ============================================
# Python
# ============================================
*.egg-info/
.pytest_cache/
.mypy_cache/

# ============================================
# Windows
# ============================================
*.exe
*.dll
*.sys
*.lnk
*.url

# ============================================
# Lingma 系统运行时数据（不跟踪）
# ============================================
.lingma/cache/
.lingma/logs/*.log
.lingma/snapshots/
.lingma/specs/spec-history/

# 注意：以下 Lingma 文件/目录会被 Git 跟踪：
# - .lingma/config/
# - .lingma/rules/
# - .lingma/skills/
# - .lingma/agents/
# - .lingma/docs/
# - .lingma/reports/
# - .lingma/scripts/
# - .lingma/hooks/
# - .lingma/specs/current-spec.md
# - .lingma/specs/templates/
# - .lingma/SYSTEM_ARCHITECTURE.md
